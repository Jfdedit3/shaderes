		end
		if obj.Name == "maintitle" or obj.Name == "title" then
			obj.FontFace = titleFont
			obj.TextColor3 = palette.text
			obj.TextTransparency = 0
		elseif obj.Name == "secondtitle" then
			obj.TextColor3 = palette.muted
			obj.TextTransparency = 0.1
		end
	end

	local function styleSurface(obj)
		if obj:IsA("ScrollingFrame") then
			obj.BackgroundColor3 = palette.panel
			obj.BackgroundTransparency = 0.08
			obj.ScrollBarImageColor3 = palette.accent
			obj.ScrollBarThickness = 5
			return
		end

		if obj:IsA("Frame") then
			if obj.Name == "main" then
				obj.BackgroundColor3 = palette.surface
				obj.BackgroundTransparency = 0.08
			elseif obj.Name == "Frame" or obj.Name == "showpage" or obj.Name == "addtionframe" then
				obj.BackgroundColor3 = palette.panel
				obj.BackgroundTransparency = 0.12
			elseif obj.Name == "functionbar" or obj.Name == "mainbar" then
				obj.BackgroundTransparency = 1
			elseif obj.BackgroundTransparency < 1 then
				obj.BackgroundColor3 = palette.panelSoft
				obj.BackgroundTransparency = math.max(obj.BackgroundTransparency, 0.08)
			end
		end
	end

	for _, obj in pairs(Z4TROXSHADER) do
		if typeof(obj) == "Instance" then
			if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
				styleText(obj)
			end

			if obj:IsA("TextButton") or obj:IsA("ImageButton") then
				obj.AutoButtonColor = true
				obj.BackgroundColor3 = palette.control
				obj.BackgroundTransparency = math.min(obj.BackgroundTransparency, 0.18)
			end

			if obj:IsA("TextBox") then
				obj.BackgroundColor3 = palette.control
				obj.BackgroundTransparency = math.min(obj.BackgroundTransparency, 0.18)
			end

			if obj:IsA("ImageButton") and (obj.Name == "minimize" or obj.Name == "feedback" or obj.Name == "setting" or obj.Name == "send") then
				obj.ImageColor3 = palette.text
			end

			styleSurface(obj)

			if obj:IsA("UIStroke") then
				obj.Enabled = true
				obj.Color = palette.stroke
				obj.Transparency = 0.55
				obj.Thickness = 1
			elseif obj:IsA("UICorner") then
				obj.CornerRadius = UDim.new(0, 8)
			end
		end
	end

	if Z4TROXSHADER["7"] then
		Z4TROXSHADER["7"].BackgroundColor3 = palette.panel
		Z4TROXSHADER["7"].BackgroundTransparency = 0.08
	end
	if Z4TROXSHADER["c"] then
		Z4TROXSHADER["c"].Text = [[ z4trox shaders]]
	end
	if Z4TROXSHADER["e"] then
		Z4TROXSHADER["e"].Text = [[]]
	end
end

return Z4TROXSHADER["1"], require;

